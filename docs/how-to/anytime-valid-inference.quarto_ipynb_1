      "source": [
        "At a 5% threshold, the decision rule for `treated` has three equivalent forms:"
      ],
      "id": "76e385ce"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Rule 1: stop when the sequential p-value is at most 0.05.\n",
        "fit.pvalue_savi(\n",
        "    mixture_precision=mixture_precision,\n",
        ").loc[\"treated\"]"
      ],
      "id": "bfab0dd4",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Rule 2: stop when the e-value is at least 20 (= 1 / 0.05).\n",
        "fit.evalue(\n",
        "    mixture_precision=mixture_precision,\n",
        ").loc[\"treated\"]"
      ],
      "id": "0d2ae64a",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Rule 3: stop when zero falls outside the confidence sequence.\n",
        "fit.confint(\n",
        "    inference_type=\"savi\",\n",
        "    mixture_precision=mixture_precision,\n",
        ").loc[\"treated\"]"
      ],
